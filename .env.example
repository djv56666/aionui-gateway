# Gateway 配置
GATEWAY_PORT=3000
GATEWAY_SESSION_SECRET=change-me-to-a-random-string
GATEWAY_SECRET=change-me-to-a-random-string

# Gateway 对外域名（用于 OAuth2 回调地址拼接，需要匹配 CAS serviceId 配置）
# GATEWAY_BASE_URL=https://skillhub.zhimi.com

# AionUi Server 路径（构建好的 dist-server 目录）
AIONUI_SERVER_ENTRY=../AionUi/dist-server/server.mjs

# 实例运行时（bun 或 node）— AionUi 用 bun 构建，需要 bun 启动
# INSTANCE_RUNTIME=bun

# 用户实例端口范围
INSTANCE_PORT_START=4001
INSTANCE_PORT_END=4100

# 用户数据根目录
INSTANCE_DATA_ROOT=./data/users

# 实例空闲超时（秒），超过此时间无活动则回收
INSTANCE_IDLE_TIMEOUT=1800

# OAuth2 — GitHub
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=

# OAuth2 — Google（可选）
# OAUTH_GOOGLE_CLIENT_ID=
# OAUTH_GOOGLE_CLIENT_SECRET=

# OAuth2 — Zhimi CAS
OAUTH_ZHIMI_CLIENT_ID=
OAUTH_ZHIMI_CLIENT_SECRET=
OAUTH_ZHIMI_CAS_BASE=https://cas.zhimi.com
