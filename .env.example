# Gateway 配置
GATEWAY_PORT=3000
GATEWAY_SESSION_SECRET=change-me-to-a-random-string
GATEWAY_SECRET=change-me-to-a-random-string

# Docker 命令路径（默认 docker，Podman 用户可改为 podman）
# DOCKER_CMD=docker

# Docker 镜像名称（需要先构建 AionUi 镜像）
DOCKER_IMAGE=aionui:latest

# 容器内部服务端口（AionUi 镜像内监听的端口）
# CONTAINER_PORT=25808

# Gateway 对外域名（用于 OAuth2 回调地址拼接，需要匹配 CAS serviceId 配置）
# GATEWAY_BASE_URL=https://aionui.zhimi.com

# 用户实例端口范围
INSTANCE_PORT_START=4001
INSTANCE_PORT_END=4100

# 用户数据根目录
INSTANCE_DATA_ROOT=./data/users

# 实例空闲超时（秒），超过此时间无活动则回收
INSTANCE_IDLE_TIMEOUT=1800

# 容器资源限制（每个用户实例）
# CONTAINER_MEMORY=512m
# CONTAINER_CPUS=1
# CONTAINER_PIDS_LIMIT=256

# OAuth2 — GitHub
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=

# OAuth2 — Google（可选）
# OAUTH_GOOGLE_CLIENT_ID=
# OAUTH_GOOGLE_CLIENT_SECRET=

# OAuth2 — Zhimi CAS
OAUTH_ZHIMI_CLIENT_ID=
OAUTH_ZHIMI_CLIENT_SECRET=
OAUTH_ZHIMI_CAS_BASE=https://cas.zhimi.com
